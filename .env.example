# AutoXSS Environment Variables Configuration
# Copy this to .env and fill in your values

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Audit & Compliance
REQUIRE_AUTHORIZATION=true
AUDIT_LOG_DIR=.audit_logs

# API Server (if using api_server.py)
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Scanning defaults
DEFAULT_THREADS=5
DEFAULT_TIMEOUT=10
DEFAULT_DELAY=0

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Blind XSS Callbacks
BLIND_CALLBACK_URL=

# Database (for storing results, optional)
DATABASE_URL=sqlite:///./xss_results.db

# Debug mode
DEBUG=false

# Request headers
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36

# Reporting
REPORT_FORMAT=json,html
REPORT_DIR=reports
